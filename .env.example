# --- Google AI Studio (free tier) -------------------------------------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Supabase (free project) -------------------------------------------------
# Project settings → API. The service-role key bypasses RLS; it must only ever
# be used server-side (pipeline scripts, Next.js API routes).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection for the Python pipeline + evals.
# Supabase: Settings → Database → connection pooler URI.
# Local dev: postgresql://postgres:test@localhost:54329/postgres
DATABASE_URL=

# Pipeline dev mode without a Gemini key: writes deterministic placeholder
# vectors instead of calling the embedding API. Never use for the live demo.
# FAKE_EMBEDDINGS=1

# --- Web app ------------------------------------------------------------------
# Salt for hashing visitor IPs in the rate limiter / query log. Any random string.
IP_HASH_SALT=change-me

# Per-IP requests per hour for /api/ask (free Gemini quota protection)
RATE_LIMIT_PER_HOUR=20

# Set to "false" to skip the Gemini Flash rerank step if quota is tight
RERANK_ENABLED=true
