# --- Google AI Studio (free tier) -------------------------------------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Supabase (free project) -------------------------------------------------
# Project settings → API. The service-role key bypasses RLS; it must only ever
# be used server-side (pipeline scripts, Next.js API routes).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Web app ------------------------------------------------------------------
# Salt for hashing visitor IPs in the rate limiter / query log. Any random string.
IP_HASH_SALT=change-me

# Per-IP requests per hour for /api/ask (free Gemini quota protection)
RATE_LIMIT_PER_HOUR=20

# Set to "false" to skip the Gemini Flash rerank step if quota is tight
RERANK_ENABLED=true
